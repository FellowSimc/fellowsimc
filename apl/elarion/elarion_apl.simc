
actions.precombat=snapshot_stats
actions.precombat+=/focused_shot

actions=run_action_list,name=hail,if=legendary.astronomers_hail
actions=run_action_list,name=deadly_focus,if=talent.deadly_focus&blessing.finesse_n=4&blessing.finesse_h=4
actions+=/run_action_list,name=main

actions.main=event_horizon,target_if=target.time_to_die>=16|fight_remains<=20,if=!weapon_trait.visions_of_grandeur|weapon.chronoshift&cooldown.chronoshift.remains>=5*weapon_trait.visions_of_grandeur|weapon.voidbringer&cooldown.voidbringers_touch.remains>=5*weapon_trait.visions_of_grandeur|!weapon.voidbringers_touch&!weapon.chronoshift
#,if=(cooldown.chronoshift.remains>0|!weapon.chronoshift)&(cooldown.voidbringer.remains>0|!weapon.voidbringer)|!weapon_trait.visions_of_grandeur
actions.main+=/icicles_of_anzhyr
actions.main+=/skystriders_grace,if=(buff.event_horizon.up&target.time_to_die>=10|(target.time_to_die>=16|fight_remains<=20))&!buff.skystriders_grace.up
actions.main+=/skystriders_supremacy,if=!buff.skystriders_supremacy.up&talent.fervent_supremacy
actions.main+=/lunarlight_mark,if=!buff.resurgent_winds.at_max_stacks|!talent.resurgent_winds
#,if=!talent.final_crescendo|!talent.resurgent_winds|buff.final_crescendo.at_max_stacks
actions.main+=/voidbringer,target_if=(target.time_to_die>=12|fight_remains<=20)&!debuff.voidbringer_accumulator.up
actions.main+=/natures_fury
actions.main+=/highwind_arrow,target_if=max:target.health*(1+0.5*debuff.lunarlight_mark.up),if=buff.resurgent_winds.up
actions.main+=/starfall_volley
# actions.main+=/multishot,if=buff.skystriders_supremacy.up&(buff.skystriders_supremacy.stack-2)*gcd.max<=buff.skystriders_supremacy.remains&(buff.skystriders_supremacy.stack)*gcd.max>=buff.skystriders_supremacy.remains
actions.main+=/highwind_arrow,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=legendary.shimmer&debuff.shimmer.remains<=gcd.max*3|charges>=(3-debuff.shimmer.stack)&legendary.shimmer&!debuff.shimmer.at_max_stacks|buff.resurgent_winds.up|talent.high_impact&weapon.chronoshift&cooldown.chronoshift.remains<=gcd.max*3
actions.main+=/heartseeker_barrage,target_if=max:debuff.lunarlight_mark.stack,if=buff.impending_heartseeker.up|debuff.lunarlight_mark.up&(talent.fusillade|!legendary.astronomers_hail)|talent.fervent_supremacy&active_enemies=1|buff.event_horizon.up
actions.main+=/chronoshift,cancel_if=gcd.remains<=0
actions.main+=/multishot,if=(is_empowered)&active_enemies<=2
actions.main+=/highwind_arrow,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=charges_fractional>=2&(!buff.skystriders_supremacy.up|talent.fervent_supremacy|talent.resurgent_winds)&active_enemies<=12
actions.main+=/celestial_shot,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=buff.celestial_impetus.react&talent.impending_heartseeker&!buff.impending_heartseeker.up
#actions.main+=/highwind_arrow,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=legendary.shimmer&charges>=2|!legendary.shimmer&(active_enemies=1|!buff.multishot.at_max_stacks)
actions.main+=/skystriders_supremacy,if=!buff.skystriders_supremacy.up&!talent.fervent_supremacy
actions.main+=/focused_shot,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=talent.impending_heartseeker&(time-action.focused_shot.last_used)>=20&time>=20
actions.main+=/highwind_arrow,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=active_enemies>=2&!buff.multishot.up&!legendary.shimmer
actions.main+=/multishot,if=buff.multishot.up&active_enemies>=2|is_empowered
actions.main+=/highwind_arrow,if=!legendary.shimmer&(active_enemies=1|!buff.multishot.at_max_stacks)
actions.main+=/heartseeker_barrage,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=active_enemies=1
actions.main+=/celestial_shot,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=focus>=60
actions.main+=/focused_shot,target_if=max:target.health*(1+debuff.shimmer.stack_value)


actions.hail=event_horizon,target_if=target.time_to_die>=16|fight_remains<=20,if=!weapon_trait.visions_of_grandeur|weapon.chronoshift&cooldown.chronoshift.remains>=5*weapon_trait.visions_of_grandeur|weapon.voidbringer&cooldown.voidbringers_touch.remains>=5*weapon_trait.visions_of_grandeur|!weapon.voidbringers_touch&!weapon.chronoshift
#,if=(cooldown.chronoshift.remains>0|!weapon.chronoshift)&(cooldown.voidbringer.remains>0|!weapon.voidbringer)|!weapon_trait.visions_of_grandeur
actions.hail+=/icicles_of_anzhyr
actions.hail+=/skystriders_grace,if=(buff.event_horizon.up&target.time_to_die>=10|(target.time_to_die>=16|fight_remains<=20))&!buff.skystriders_grace.up
actions.hail+=/skystriders_supremacy,if=!buff.skystriders_supremacy.up&talent.fervent_supremacy
actions.hail+=/lunarlight_mark,if=!buff.resurgent_winds.at_max_stacks|!talent.resurgent_winds
#,if=!talent.final_crescendo|!talent.resurgent_winds|buff.final_crescendo.at_max_stacks
actions.hail+=/voidbringer,target_if=(target.time_to_die>=12|fight_remains<=20)&!debuff.voidbringer_accumulator.up
actions.hail+=/natures_fury
actions.hail+=/highwind_arrow,if=active_enemies<3&talent.strikers_aim&(!buff.strikers_aim.at_max_stacks|buff.strikers_aim.remains<=4)
actions.hail+=/starfall_volley
actions.hail+=/chronoshift,if=cooldown.starfall_volley.remains>10
actions.hail+=/heartseeker_barrage,target_if=max:debuff.lunarlight_mark.stack,if=active_enemies=1|buff.event_horizon.up|!buff.starfall_volleys.up&debuff.lunarlight_mark.stack>1,cancel_if=debuff.lunarlight_mark.stack=0&active_enemies>1
actions.hail+=/celestial_shot,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=buff.celestial_impetus.react&buff.event_horizon.up&talent.impending_heartseeker
actions.hail+=/skystriders_supremacy,if=!buff.skystriders_supremacy.up&!talent.fervent_supremacy&(buff.stars_aligned.stack<1)
#actions.hail+=/highwind_arrow,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=active_enemies>=2&!buff.multishot.up&!legendary.shimmer&full_recharge_time<=gcd.max*3
actions.hail+=/multishot,if=(is_empowered|active_enemies>1)|buff.starfall_volleys.up&legendary.astronomers_hail
actions.hail+=/celestial_shot,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=buff.celestial_impetus.react&active_enemies<3
actions.hail+=/highwind_arrow,if=(!buff.multishot.up&active_enemies>2|active_enemies<3&talent.strikers_aim&(!buff.strikers_aim.at_max_stacks|buff.strikers_aim.remains<=5|full_recharge_time<=gcd.max*3)|talent.high_impact)
actions.hail+=/celestial_shot,target_if=max:target.health*(1+debuff.shimmer.stack_value),if=focus>=40&active_enemies=1
actions.hail+=/focused_shot,target_if=max:target.health*(1+debuff.shimmer.stack_value)

actions.deadly_focus=event_horizon,target_if=target.time_to_die>=16|fight_remains<=20,if=!weapon_trait.visions_of_grandeur|weapon.chronoshift&cooldown.chronoshift.remains>=5*weapon_trait.visions_of_grandeur|weapon.voidbringer&cooldown.voidbringers_touch.remains>=5*weapon_trait.visions_of_grandeur|!weapon.voidbringers_touch&!weapon.chronoshift
actions.deadly_focus+=/icicles_of_anzhyr
#,if=(cooldown.chronoshift.remains>0|!weapon.chronoshift)&(cooldown.voidbringer.remains>0|!weapon.voidbringer)|!weapon_trait.visions_of_grandeur
actions.deadly_focus+=/skystriders_grace,if=(buff.event_horizon.up&target.time_to_die>=10|(target.time_to_die>=16|fight_remains<=20))&!buff.skystriders_grace.up
actions.deadly_focus+=/skystriders_supremacy,if=!buff.finesse_g.up
actions.deadly_focus+=/lunarlight_mark,if=!buff.resurgent_winds.at_max_stacks|!talent.resurgent_winds
#,if=!talent.final_crescendo|!talent.resurgent_winds|buff.final_crescendo.at_max_stacks
actions.deadly_focus+=/voidbringer,target_if=(target.time_to_die>=12|fight_remains<=20)&!debuff.voidbringer_accumulator.up
actions.deadly_focus+=/natures_fury
actions.deadly_focus+=/highwind_arrow,if=debuff.shimmer.remains<=gcd.max*3&legendary.shimmer|buff.resurgent_winds.up|full_recharge_time<=gcd.max|charges>=2&talent.resurgent_winds
actions.deadly_focus+=/starfall_volley
actions.deadly_focus+=/highwind_arrow,if=!debuff.shimmer.at_max_stacks&legendary.shimmer
actions.deadly_focus+=/highwind_arrow,if=talent.strikers_aim&(active_enemies<3|talent.final_crescendo)
actions.deadly_focus+=/chronoshift,if=cooldown.starfall_volley.remains>10
actions.deadly_focus+=/heartseeker_barrage,target_if=max:debuff.lunarlight_mark.stack,cancel_if=debuff.lunarlight_mark.stack=0&gcd.remains<=0&active_enemies>2,if=buff.impending_heartseeker.up|debuff.lunarlight_mark.stack>2&active_enemies>1|active_enemies=1&debuff.lunarlight_mark.stack>8
actions.deadly_focus+=/celestial_shot,if=buff.finesse_n.at_max_stacks
# This should not happen just checking if it does
actions.deadly_focus+=/focused_shot,if=buff.finesse_n.at_max_stacks
actions.deadly_focus+=/celestial_shot
actions.deadly_focus+=/focused_shot