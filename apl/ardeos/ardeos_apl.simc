
actions.precombat=snapshot_stats
actions.precombat+=/infernal_wave

actions=run_action_list,name=main

actions.main=apocalypse,target_if=max:target.health,if=(legendary.explosivo&target.time_to_die>=40|!raid_event.adds.exists|(raid_event.adds.in>=55|(active_enemies-active_dot.searing_blaze)>=1&legendary.explosivo|(active_enemies-active_dot.searing_blaze)>=3&!legendary.explosivo)&target.time_to_die>=15|active_enemies=1&legendary.explosivo&raid_event.adds.in>=40)&buff.apocalyptic_surge.stack<3
#&(!buff.wildfire.up|legendary.explosivo|cinders<100&talent.apocalyptic_surge&!buff.apocalyptic_surge.up)
actions.main+=/icicles_of_anzhyr,if=(!raid_event.adds.exists|active_enemies%2>=raid_event.adds.count|raid_event.adds.in>=12)&(active_dot.curse_of_anzhyr<active_enemies|!raid_event.adds.exists|raid_event.adds.in>=30)
actions.main+=/fire_ball,if=full_recharge_time<=(gcd.max*3)|(active_dot.fire_ball_dot=0)&(active_dot.engulfing_flames>0|cooldown.wildfire.remains<=gcd.max*3|!talent.slow_burn)|weapon.chronoshift&cooldown.chronoshift.up&!talent.slow_burn
#,if=dot.searing_blaze.refreshable
actions.main+=/fire_frogs,if=cooldown.wildfire.up&(legendary.fire_toad|active_enemies<12|talent.pyrophibian_frenzy)&cooldown.engulfing_flames.full_recharge_time>gcd.max
actions.main+=/engulfing_flames,target_if=max:target.health,if=full_recharge_time<=(gcd.max*3+talent.rolling_flames&active_dot.searing_blaze*0.4)&(cooldown.wildfire.remains>=10|talent.rolling_flames)|cooldown.wildfire.remains<=gcd.max*2|buff.wildfire.up|cooldown.chronoshift.up&weapon.chronoshift
actions.main+=/voidbringers_touch,target_if=max:target.health,if=buff.wildfire.up
# actions.main+=/engulfing_flames
#,if=!buff.wildfire.up&active_enemies>1|cooldown.wildfire.remains>=10|cooldown.wildfire.remains<=gcd.max*3|talent.rolling_flames
actions.main+=/wildfire,if=active_dot.engulfing_flames>0|cooldown.pyromania.up
actions.main+=/pyromania,if=buff.wildfire.up
actions.main+=/chronoshift,if=!cooldown.wildfire.up|fight_remains<=30
actions.main+=/incinerate,target_if=min:dot.engulfing_flames.remains-100*dot.engulfing_flames.ticking-100*target.time_to_die>=12,if=(active_dot.engulfing_flames>=2&action.engulfing_flames.shortest_active_engulf<=5|dot.apocalypse_dot.remains<=3&dot.apocalypse_dot.ticking|!talent.undying_flame&(active_dot.engulfing_flames>0&action.engulfing_flames.shortest_active_engulf<=5))|(time-action.chronoshift.last_used)<=10
#,if=active_dot.engulfing_flames>=2&action.engulfing_flames.shortest_active_engulf>execute_time&(action.engulfing_flames.shortest_active_engulf<=2|action.engulfing_flames.shortest_active_engulf<=5&active_enemies>=8)&(!weapon_trait.visions_of_grandeur|!weapon.chronoshift|cooldown.chronoshift.remains>=10)
#(!buff.wildfire.up|active_enemies=1)&(spirit.time_to_max<=5|active_dot.engulfing_flames>=4&active_enemies=1|active_dot.engulfing_flames>=10|!weapon_trait.visions_of_grandeur|!weapon.chronoshift|cooldown.chronoshift.remains>=90|fight_remains<=30|!talent.undying_flame&!talent.rolling_flames&!talent.slow_burn&active_enemies=1)
actions.main+=/infernal_wave,target_if=max:dot.engulfing_flames.stack,if=buff.cascading_inferno.stack>=18
actions.main+=/detonate,if=(active_dot.engulfing_flames>=1)&cinders>=300|buff.wildfire.up
#actions.main+=/searing_blaze,target_if=refreshable&target.time_to_die>=12,if=cooldown.apocalypse.remains>=10|raid_event.adds.in<=30|(active_enemies-active_dot.searing_blaze)<4|active_enemies<=4
actions.main+=/detonate,if=active_dot.searing_blaze>=6&active_dot.engulfing_flames>1
actions.main+=/natures_fury
actions.main+=/detonate,if=cinders>=360&(active_dot.searing_blaze>=4|active_dot.apocalypse>0)
actions.main+=/infernal_wave,target_if=max:target.health


