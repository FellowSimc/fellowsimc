report_details=1
optimal_raid=0
# max_time=420
max_time=50
target_error=0.1
iterations=100000
chart_show_relative_difference=1
vary_combat_length=0
single_actor_batch=1
desired_targets=20


# apl/chuey_dungeon.simc

# apl/dungeon.simc

scale_only=crit,haste,mastery,vers
scale_intellect=100
scale_crit_rating=590
scale_haste_rating=590
scale_mastery_rating=590
scale_versatility_rating=590
positive_scale_delta=1
