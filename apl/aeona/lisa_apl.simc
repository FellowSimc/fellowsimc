
actions.precombat=snapshot_stats
actions.precombat+=/time_shard

actions=run_action_list,name=main

actions.spend=oblivion,target_if=max:debuff.unfolding_doom.remains,if=debuff.unfolding_doom.remains
actions.spend+=/oblivion,target_if=max:target.health


actions.main=fleeting_hour
actions.main+=/alzeracs_essence,if=mana.pct<=60
actions.main+=/unfolding_doom,target_if=max:target.health
# actions.main+=/natures_fury,target_if=debuff.unfolding_doom.up
actions.main+=/epoch_break,if=!buff.fleeting_hour.up
actions.main+=/call_action_list,name=spend,if=chrona>=50&talent.synchronicity|buff.epoch_break.up
actions.main+=/temporal_barrage,target_if=max:target.health,if=!buff.epoch_break.up
actions.main+=/entropys_calm,target_if=max:target.health,if=refreshable
actions.main+=/call_action_list,name=spend,target_if=max:debuff.unfolding_doom.remains,if=debuff.unfolding_doom.up|chrona>=60
actions.main+=/time_shard

