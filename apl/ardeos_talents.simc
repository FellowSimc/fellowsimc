# dps_plot_stat=haste,crit_rating,mastery,versatility
# dps_plot_stat=haste:0,mastery:0,crit:0,versatility:0
# dps_plot_points=10
# dps_plot_step=300
# dps_plot_positive=1

ardeos="Ardeos"
level=80

initial_resource=spirit=100
initial_resource=cinders=200

apl/ardeos_apl.simc

gear_intellect=1442

# gear_haste_rating=1650
gear_haste_rating=1150
gear_crit_rating=1815
gear_versatility_rating=1350
